# lint / format ツールのキャッシュ
.ruff_cache/
.rumdl_cache/

# Python の生成物
__pycache__/
*.pyc
.venv/
venv/
# このリポは Python project ではない (pyproject.toml 参照)。スクリプトは PEP 723 inline
# script で依存を持つため uv.lock は不要。uv run/sync が生成しても commit しない。
uv.lock

# mise のローカル override (個人マシン固有の設定)
.mise.local.toml

# discover-signals skill の出力先 (extract_signals.py のデフォルト)
.triage/
